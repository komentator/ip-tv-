<Window x:Class="IpTvPlayer.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="380" Width="560"
        Background="#252526" Foreground="White"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="URL EPG (XMLTV):" FontSize="13" Margin="0,0,0,5"/>
        <TextBox Grid.Row="1" x:Name="EpgUrlBox" Padding="8" Background="#3c3c41" Foreground="White" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="2" Text="Громкость по умолчанию:" FontSize="13" Margin="0,0,0,5"/>
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0" x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="100"
                    VerticalAlignment="Center" ValueChanged="VolumeSlider_ValueChanged"/>
            <TextBlock Grid.Column="1" x:Name="VolumeLabel" Text="100" VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </Grid>

        <TextBlock Grid.Row="4" Text="Папка для скриншотов:" FontSize="13" Margin="0,0,0,5"/>
        <Grid Grid.Row="5" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="SnapshotDirBox" Padding="8" Background="#3c3c41" Foreground="White"/>
            <Button Grid.Column="1" Content="Обзор..." Margin="10,0,0,0" Padding="8,5" Background="#3e3e42" Foreground="White" Click="Browse_Click"/>
        </Grid>

        <TextBlock Grid.Row="6" x:Name="StatusText" FontSize="11" Foreground="#888888" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Width="100" Margin="0,0,10,0" Padding="8,5" Background="#3e3e42" Foreground="White" Click="Cancel_Click" IsCancel="True"/>
            <Button Content="Сохранить" Width="120" Padding="8,5" Background="#0e639c" Foreground="White" Click="Save_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
