<Window x:Class="IpTvPlayer.Views.HotkeysHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Горячие клавиши" Height="420" Width="480"
        Background="#252526" Foreground="White"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Горячие клавиши" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Space" Foreground="#ffc107" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Воспроизведение / пауза"/>
                </Grid>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="S" Foreground="#ffc107" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Остановить"/>
                </Grid>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="F / F11" Foreground="#ffc107" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Полноэкранный режим"/>
                </Grid>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Esc" Foreground="#ffc107" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Выйти из полного экрана"/>
                </Grid>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="M" Foreground="#ffc107" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Отключить / включить звук"/>
                </Grid>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="↑ / ↓" Foreground="#ffc107" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Громкость +/- 5"/>
                </Grid>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="← / →" Foreground="#ffc107" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Предыдущий / следующий канал"/>
                </Grid>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="F1" Foreground="#ffc107" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Эта справка"/>
                </Grid>

                <TextBlock Text="Мышь" FontSize="14" FontWeight="Bold" Margin="0,15,0,5"/>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Двойной клик" Foreground="#ffc107" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Переключить полный экран"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="ОК" Width="100" HorizontalAlignment="Right" Padding="8,5"
                Background="#0e639c" Foreground="White" Click="Close_Click" IsCancel="True" IsDefault="True"/>
    </Grid>
</Window>
