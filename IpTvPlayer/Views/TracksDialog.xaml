<Window x:Class="IpTvPlayer.Views.TracksDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Аудио и субтитры" Height="320" Width="420"
        Background="#252526" Foreground="White"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Аудиодорожка:" FontSize="13" Margin="0,0,0,5"/>
        <ComboBox Grid.Row="1" x:Name="AudioBox" Background="#3c3c41" Foreground="White" Padding="8,5"
                  SelectionChanged="AudioBox_SelectionChanged" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="2" Text="Субтитры:" FontSize="13" Margin="0,0,0,5"/>
        <ComboBox Grid.Row="3" x:Name="SubBox" Background="#3c3c41" Foreground="White" Padding="8,5"
                  SelectionChanged="SubBox_SelectionChanged"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Закрыть" Width="100" Padding="8,5" Background="#0e639c" Foreground="White" Click="Close_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
