<Window x:Class="IpTvPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="IP TV Player" Height="720" Width="1280" Background="#1e1e1e" Foreground="#ffffff"
        Loaded="Window_Loaded" KeyDown="Window_KeyDown" Focusable="True">
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" x:Name="TopBarRow"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60" x:Name="BottomBarRow"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" x:Name="SidebarCol"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Title Bar -->
        <Border x:Name="TopBar" Grid.ColumnSpan="2" Background="#252526" Padding="15,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="IP TV Player" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="TitleInfo" FontSize="12" VerticalAlignment="Center" Foreground="#888888" Margin="0,0,15,0"/>
                <TextBlock x:Name="EpgInfo" FontSize="12" VerticalAlignment="Center" Foreground="#cccccc" Margin="0,0,15,0"/>
                <TextBlock x:Name="StreamInfo" FontSize="11" VerticalAlignment="Center" Foreground="#888888"/>
            </StackPanel>
        </Border>

        <!-- Sidebar with Playlists -->
        <Border x:Name="Sidebar" Grid.Row="1" Background="#252526" BorderThickness="0,0,1,0" BorderBrush="#3e3e42">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#2d2d30" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Плейлисты" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Button Content="+ Импорт" Padding="8,5" Background="#0e639c" Foreground="White" Click="ImportPlaylist_Click" Margin="0,0,0,5"/>
                        <Button Content="📡 EPG" Padding="8,5" Background="#3e3e42" Foreground="White" Click="EpgRefresh_Click"/>
                    </StackPanel>
                </Border>

                <ListBox x:Name="PlaylistsList" Background="Transparent" BorderThickness="0"
                         SelectionChanged="Playlist_SelectionChanged" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" Background="Transparent">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="🔄 Обновить" Click="PlaylistRefresh_Click" Tag="{Binding}"/>
                                        <MenuItem Header="✏ Переименовать" Click="PlaylistRename_Click" Tag="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="🗑 Удалить" Click="PlaylistDelete_Click" Tag="{Binding}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Channels.Count, StringFormat='Каналов: {0}'}" FontSize="10" Foreground="#888888"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#0e639c"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3e3e42"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" x:Name="FilterRow"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search and Filter -->
            <Border x:Name="FilterBar" Background="#2d2d30" Padding="15" Grid.Row="0">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton x:Name="ViewAll" Content="Все" IsChecked="True" Foreground="White" Margin="0,0,15,0" GroupName="ViewMode" Checked="ViewAll_Checked"/>
                        <RadioButton x:Name="ViewFavorites" Content="★ Избранное" Foreground="White" Margin="0,0,15,0" GroupName="ViewMode" Checked="ViewFavorites_Checked"/>
                        <RadioButton x:Name="ViewRecent" Content="🕒 История" Foreground="White" GroupName="ViewMode" Checked="ViewRecent_Checked"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox" Padding="8,8" Background="#3c3c41" Foreground="White" TextChanged="Search_TextChanged"/>
                        <ComboBox x:Name="GroupFilter" Grid.Column="1" Padding="8,8" Margin="10,0,0,0" Background="#3c3c41" Foreground="White" SelectionChanged="Group_SelectionChanged"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Channels List and Video Player -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350" x:Name="ChannelsCol"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ListBox x:Name="ChannelsList" Background="#1e1e1e" BorderThickness="1,0,0,0" BorderBrush="#3e3e42"
                         SelectionChanged="Channel_SelectionChanged" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" BorderThickness="0,0,0,1" BorderBrush="#3e3e42" Background="Transparent">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="▶ Воспроизвести" Click="ChannelPlay_Click" Tag="{Binding}"/>
                                        <MenuItem Header="★ В избранное / убрать" Click="ChannelFavorite_Click" Tag="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="📋 Копировать URL" Click="ChannelCopyUrl_Click" Tag="{Binding}"/>
                                        <MenuItem Header="📋 Копировать название" Click="ChannelCopyName_Click" Tag="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="📅 Программа канала" Click="ChannelSchedule_Click" Tag="{Binding}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Image Grid.Column="0" Source="{Binding LogoUrl}" Width="40" Height="40" Stretch="UniformToFill" Margin="0,0,10,0"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="{Binding GroupTitle}" FontSize="10" Foreground="#888888"/>
                                    </StackPanel>

                                    <Button Grid.Column="2" Content="{Binding FavoriteIcon}" Tag="{Binding}"
                                            Click="Favorite_Click" FontSize="18" Foreground="#ffc107"
                                            Background="Transparent" BorderThickness="0" Padding="6,0"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#0e639c"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2d2d30"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Video Player Area -->
                <Grid Grid.Column="1" Background="#000000" MouseLeftButtonDown="VideoArea_MouseLeftButtonDown">
                    <vlc:VideoView x:Name="VideoView"/>
                    <TextBlock x:Name="VideoPlaceholder" Text="Выберите канал для воспроизведения"
                               FontSize="18" Foreground="#666666" TextAlignment="Center"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <Border x:Name="BufferOverlay" Background="#80000000" Visibility="Collapsed" IsHitTestVisible="False">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="BufferText" Text="Загрузка..." FontSize="20" Foreground="White" TextAlignment="Center"/>
                            <ProgressBar x:Name="BufferProgress" Width="220" Height="6" Margin="0,10,0,0"
                                         Minimum="0" Maximum="100" Foreground="#0e639c" Background="#3e3e42" BorderThickness="0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Control Bar -->
        <Border x:Name="BottomBar" Grid.Row="2" Grid.ColumnSpan="2" Background="#2d2d30" Padding="15,10">
            <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                <Button Content="▶" Padding="10,5" Background="#0e639c" Foreground="White" Margin="0,0,5,0" Click="Play_Click"/>
                <Button Content="⏸" Padding="10,5" Background="#0e639c" Foreground="White" Margin="0,0,5,0" Click="Pause_Click"/>
                <Button Content="⏹" Padding="10,5" Background="#0e639c" Foreground="White" Margin="0,0,15,0" Click="Stop_Click"/>
                <Button Content="⛶" ToolTip="Полноэкранный режим (F)" Padding="10,5" Background="#3e3e42" Foreground="White" Margin="0,0,5,0" Click="Fullscreen_Click"/>
                <Button Content="📸" ToolTip="Скриншот" Padding="10,5" Background="#3e3e42" Foreground="White" Margin="0,0,5,0" Click="Snapshot_Click"/>
                <Button Content="🎵" ToolTip="Аудио / субтитры" Padding="10,5" Background="#3e3e42" Foreground="White" Margin="0,0,5,0" Click="Tracks_Click"/>
                <Button Content="📅" ToolTip="Программа передач" Padding="10,5" Background="#3e3e42" Foreground="White" Margin="0,0,5,0" Click="Schedule_Click"/>
                <Button Content="⚙" ToolTip="Настройки" Padding="10,5" Background="#3e3e42" Foreground="White" Click="Settings_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center">
                <Button x:Name="MuteButton" Content="🔊" Padding="10,5" Background="#3e3e42" Foreground="White" Margin="0,0,10,0" Click="Mute_Click"/>
                <TextBlock Text="Громкость:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Slider x:Name="VolumeSlider" Width="150" Maximum="100" Minimum="0" Value="100"
                        VerticalAlignment="Center" ValueChanged="Volume_Changed"/>
            </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
